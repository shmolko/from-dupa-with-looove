{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/from-dupa-with-looove/lesson.schema.json",
  "title": "GeneratedLesson",
  "type": "object",
  "additionalProperties": false,
  "required": ["topic", "focus", "items"],
  "properties": {
    "topic": {
      "type": "string",
      "enum": ["reflexive_verbs"]
    },
    "focus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["goal", "recentWeakPatterns"],
      "properties": {
        "goal": {
          "type": "string"
        },
        "recentWeakPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "items": {
      "type": "array",
      "minItems": 5,
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "patternId",
          "difficulty",
          "prompt",
          "explanation",
          "hint"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["multiple_choice", "sentence_judgment"]
          },
          "patternId": {
            "type": "string",
            "enum": ["particle_presence", "se_vs_si", "argument_structure_contrast"]
          },
          "difficulty": {
            "type": "integer",
            "enum": [1, 2, 3]
          },
          "prompt": {
            "type": "string"
          },
          "choices": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sentence": {
            "type": "string"
          },
          "isSentenceCorrect": {
            "type": "boolean"
          },
          "acceptedAnswers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "explanation": {
            "type": "string"
          },
          "hint": {
            "type": "string"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "type": {
                  "const": "multiple_choice"
                }
              }
            },
            "then": {
              "required": ["choices", "acceptedAnswers"]
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "const": "sentence_judgment"
                }
              }
            },
            "then": {
              "required": ["sentence", "isSentenceCorrect"]
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "const": "sentence_judgment"
                },
                "isSentenceCorrect": {
                  "const": false
                }
              }
            },
            "then": {
              "required": ["acceptedAnswers"]
            }
          }
        ]
      }
    }
  },
  "examples": [
    {
      "topic": "reflexive_verbs",
      "focus": {
        "goal": "Rozhodnout, zda má být ve větě `se`, `si`, nebo nic.",
        "recentWeakPatterns": ["particle_presence", "argument_structure_contrast"]
      },
      "items": [
        {
          "type": "sentence_judgment",
          "patternId": "particle_presence",
          "difficulty": 1,
          "prompt": "Je tato věta správně?",
          "sentence": "Po schůzce se mluvila s kolegyní.",
          "isSentenceCorrect": false,
          "acceptedAnswers": ["Po schůzce mluvila s kolegyní."],
          "explanation": "Sloveso `mluvit` tu zvratnou částici nepotřebuje.",
          "hint": "Když je `se` navíc, uživatel může opravit jen část věty, která chybu opravdu nese."
        }
      ]
    }
  ]
}
